{
  "name": "devicegrid-desktop",
  "version": "1.0.0",
  "description": "DeviceGrid - Server Fleet Management Desktop App",
  "main": "main.js",
  "author": "DeviceGrid",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:linux": "electron-builder --linux",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.devicegrid.desktop",
    "productName": "DeviceGrid",
    "directories": { "output": "release" },
    "files": ["main.js", "icon.png"],
    "extraResources": [
      { "from": "../bin/devicegrid-server", "to": "bin/devicegrid-server" }
    ],
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Utility"
    },
    "win": {
      "target": ["nsis"]
    },
    "mac": {
      "target": ["dmg"]
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
