# /etc/devicegrid/devicegrid.env
# Secrets required in production (set before `systemctl start devicegrid`).
# DO NOT commit this file — add to .gitignore.

# JWT signing secret (32+ random bytes recommended)
DG_AUTH_JWT_SECRET=replace-me-with-32-bytes-of-random-base64

# Master encryption key for SSH private keys (64 hex chars / 32 bytes)
DG_CRYPTO_MASTER_KEY=replace-me-with-64-hex-chars

# Initial admin password — CHANGE after first login
DG_DEFAULT_ADMIN_PASSWORD=changeme-now

# Server config
DG_SERVER_MODE=release
DG_LISTEN_ADDR=:3000
DG_DATA_DIR=/var/lib/devicegrid
DG_CERTS_DIR=/etc/devicegrid/certs
DG_CONFIG=/etc/devicegrid/config.yaml